# Marketplace — frontend en producción (una instancia por subdominio de tenant o proxy).
# Copia a `.env.production` en el servidor de build o define estas variables en el entorno del proceso Node.
#
# El API es el mismo para todos los tenants: siempre api.publivalla.com (NEXT_PUBLIC_API_URL).
# Cada SPA vive en {slug}.publivalla.com; el navegador envía ese Origin al API para resolver el workspace.

NEXT_PUBLIC_API_URL=https://api.publivalla.com
# Fallback de apiBase si falta la URL (p. ej. `https://api.${NEXT_PUBLIC_TENANT_BASE_DOMAIN}`). Usado por rewrites `/media/*` en `next.config.mjs`.
NEXT_PUBLIC_TENANT_BASE_DOMAIN=publivalla.com
