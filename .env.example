NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# URL pública de la plataforma (fallback “owner inexistente”, enlaces de pie).
# NEXT_PUBLIC_PUBLIVALLA_SITE_URL=https://publivalla.com
# En producción: un solo API (https://api.publivalla.com) para todos los subdominios de tenant.
# Opcional en local (sin subdominio): mismo slug que DEFAULT_WORKSPACE_SLUG del backend.
# NEXT_PUBLIC_WORKSPACE_SLUG=sambil
# En producción multi-tenant: mismo apex que TENANT_BASE_DOMAIN del backend.
# NEXT_PUBLIC_TENANT_BASE_DOMAIN=publivalla.com
# Local con http://nobis.localhost:3000 (carrito / storage por slug):
# NEXT_PUBLIC_TENANT_BASE_DOMAIN=localhost
